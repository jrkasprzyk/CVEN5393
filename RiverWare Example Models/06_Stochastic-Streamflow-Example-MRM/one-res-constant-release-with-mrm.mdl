"$s" order 1 
"$s" UUID {74f178fb-6960-41d7-b372-faaab04b8772}
"$s" computedByExpr 5 {IF ( $ "Res1.Outflow" [] > "VolumeToFlow"( $ "Res1.Demand Vol" [], @"t" ) )\
 THEN\
  0.00000000 "cfs"\
 ELSE\
  "VolumeToFlow"( $ "Res1.Demand Vol" [], @"t" ) - $ "Res1.Outflow" []\
 ENDIF COMMENTED_BY "Calculate the demand deficit, in terms of flow units, for each timestep. <br>"}
