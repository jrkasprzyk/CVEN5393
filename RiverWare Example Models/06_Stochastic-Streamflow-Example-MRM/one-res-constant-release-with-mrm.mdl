  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_REMOVE" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_ITEM" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_SUBSTITUTE" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_FORITEM" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_OF" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_INDEX" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_FROM" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_PRINT" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_EXEC_SCRIPT" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_ADD_SCONSTRAINT" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_ADD_HCONSTRAINT" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_MINIMIZE" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_MAXIMIZE" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_FREEZE" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_SUMMATION" priority="0" before="0" after="1" indentBef="0" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_RMAXIMIN" priority="0" before="0" after="1" indentBef="0" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_SMAXIMIN" priority="0" before="0" after="1" indentBef="0" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_REWARD_TABLE" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_ENDSUMMATION" priority="0" before="1" after="1" indentBef="0" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_ENDMAXIMIN" priority="0" before="1" after="1" indentBef="0" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_REWARD_TABLE_END" priority="0" before="1" after="1" indentBef="0" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_CREATE_RESTORE_POINT" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_COMMENT" priority="0" before="1" after="1" indentBef="0" indentAft="0"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_STAT_SUM" priority="0" before="0" after="1" indentBef="0" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_STAT_AVE" priority="0" before="0" after="1" indentBef="0" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_STOP_RUN" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_WARNING" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_NOTICE" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <LineBreak type="BreakType_TOKEN" symb="VisTokSym_ALERT" priority="40" before="0" after="0" indentBef="5" indentAft="5"/>\
  <TextColor type="RplColor_DEFAULT_FG" colorARGB="#ff000000"/>\
  <TextColor type="RplColor_SEL_DEFAULT_FG" colorARGB="#ffc0c0c0"/>\
  <TextColor type="RplColor_TYPES_NAMES_VALS" colorARGB="#ff2600ff"/>\
  <TextColor type="RplColor_SEL_TYPES_NAMES_VALS" colorARGB="#ffc0c0c0"/>\
  <TextColor type="RplColor_PREDEF_FUNCTIONS" colorARGB="#ff0ab400"/>\
  <TextColor type="RplColor_COMMENTS" colorARGB="#ffd12e31"/>\
  <TextColor type="RplColor_DIS_FUNCTIONS" colorARGB="#ff9f1535"/>\
  <TextColor type="RplColor_THE_BG" colorARGB="#ffffffff"/>\
  <TextColor type="RplColor_SELECTION_BG" colorARGB="#ffffffb4"/>\
  <TextColor type="RplColor_DIS_OBJS_XHATCH" colorARGB="#ffc0c0c0"/>\
  <TextColor type="RplColor_FUNCTIONS" colorARGB="#ff844800"/>\
  <TextColor type="RplColor_EXPRESSIONS" colorARGB="#ff430067"/>\
  <TextColor type="RplColor_EXPRESSIONS_BG" colorARGB="#fff5f5f5"/>\
  <ShowElemNumbers value="false" />\
  <HighlightSelEquivs value="false" />\
</RplDisplaySettings>}
# Section: Script Manager
Section {Script Manager}
# ScriptGroup: All Scripts
$ws.rwScriptMgr rwScriptGroup {\
<rwScriptGroup>\
   <ScriptGroupName>All Scripts</ScriptGroupName>\
</rwScriptGroup>\
}
# Show Script Manager On Model Open
$ws.rwScriptMgr rwShowScriptMgrOnModelLoad {\
<ShowScriptMgrOnModelLoad>\
   <YesOrNo>false</YesOrNo>\
   <DefaultScriptGroup>All Scripts</DefaultScriptGroup>\
   <ResizeToTabs count="0"/>\
</ShowScriptMgrOnModelLoad>\
}
# Run Script Group On Model Open
$ws.rwScriptMgr rwRunScriptGroupOnModelLoad {\
<RunScriptGroupOnModelLoad>\
   <YesOrNo>false</YesOrNo>\
   <RunScriptGroup></RunScriptGroup>\
</RunScriptGroupOnModelLoad>\
}
# Section: Object Attribute Manager
Section {Object Attribute Manager}
# Section: Object Attribute Set
"$ws.objectAttribMgr" objectAttribSet {<ObjAttributeSet/>}
# Section: Comparison Tool
"$ws.comparisonTool" modelFilter {<Filter Type="model">\
    <OnlyDifferences Value="true"/>\
    <MatchSpecs/>\
</Filter>}
"$ws.comparisonTool" rplFilter {<Filter Type="rpl">\
    <OnlyDifferences Value="true"/>\
    <MatchSpecs/>\
</Filter>}
# Section: Window Layout Manager
"$ws.windowLayoutManager" layouts {<WindowLayouts/>}
# Section: Multi-Window Manager
"$ws.multiWindowManager" multiWindows {<MultiWindows/>}
# Section: END (successful completion)
Section {Done}

