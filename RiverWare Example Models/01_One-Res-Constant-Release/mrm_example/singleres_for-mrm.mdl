Diag Advanced 0
Diag showDiagOutputOnRplWarning 0
Diag showDiagOutputOnRplNotice 0
Diag showDiagOutputOnRplAlert 0
# Section: Global Functions Set Manager
Section {Gobal Functions Set Manager}
$ws.GlobalRplSetMgr saveSetsWithModel true
$ws.GlobalRplSetMgr globalFunctionSet {RULESET\
NAME "Objective Function Set";\
AGENDA_ORDER ASCENDING;\
DESCRIPTION "";\
PRECISION   2;\
IS_GLOBAL   TRUE;\
NOTES "";\
BEGIN\
\
  UTILITY_GROUP "Objective Functions";\
  DESCRIPTION   "";\
  ACTIVE        TRUE;\
  NOTES          "";\
  BEGIN\
\
    FUNCTION       "TimeBasedReliability" ( SLOT slot, NUMERIC target, STRING direction )\
    RETURN_TYPE    NUMERIC;\
    SCALE_UNITS    "";\
    DESCRIPTION    "";\
    ACTIVE         TRUE;\
    PRE_EXEC_DIAG  FALSE;\
    POST_EXEC_DIAG FALSE;\
    NOTES          "";\
    BEGIN\
\
      "GetNumberOfSatisfactoryTimesteps"( slot, target, direction ) COMMENTED_BY "An acceptable state is defined as 'slot' having a value greater than or equal to 'threshold'. <br>Time-based reliability is the number of timesteps with acceptable performance divided by <br>the total number of timesteps in the simulation; 1.0 is the best possible value and 0.0 is the <br>worst. <br>" / "GetNumberOfTimesteps"(  );\
\
    END\
    UUID "{bc46fa5f-5ae7-4062-bd3a-3edde9a68a57}";;\
\
  END\
  UUID "{980c7fd2-6b15-4799-98a2-4d40e6f41994}";;\
\
  UTILITY_GROUP "Helper Functions";\
  DESCRIPTION   "";\
  ACTIVE        TRUE;\
  NOTES          "";\
  BEGIN\
\
    FUNCTION       "GetNumberOfTimesteps" (  )\
    RETURN_TYPE    NUMERIC;\
    SCALE_UNITS    "";\
    DESCRIPTION    "";\
    ACTIVE         TRUE;\
    PRE_EXEC_DIAG  FALSE;\
    POST_EXEC_DIAG FALSE;\
    NOTES          "";\
    BEGIN\
\
      LENGTH "GetRunRange"(  );\
\
    END\
    UUID "{1ff1ca4b-88ce-48e3-8e63-019e4845d44b}";;\
\
    FUNCTION       "IsSatisfactory" ( NUMERIC value, NUMERIC target, STRING direction )\
    RETURN_TYPE    NUMERIC;\
    SCALE_UNITS    "";\
    DESCRIPTION    "";\
    ACTIVE         TRUE;\
    PRE_EXEC_DIAG  FALSE;\
    POST_EXEC_DIAG FALSE;\
    NOTES          "";\
    BEGIN\
\
      IF ( direction == ">=" )\
 THEN\
  IF ( value >= target )\
  THEN\
   1.00000000\
  ELSE\
   0.00000000\
  ENDIF\
 ELSE\
  STOP_RUN "The variable STRING direction takes the logical operators from the RPL pallete: >, >=, <, <=, ==, !=. An invalid direction was supplied!"\
 ENDIF\
 ELSEIF_COND ( direction == "<=" )\
 ELSEIF_CLAUSE ( IF ( value <= target )\
 THEN\
  1.00000000\
 ELSE\
  0.00000000\
 ENDIF )\
 END_ELSEIF\
 ELSEIF_COND ( direction == "==" )\
 ELSEIF_CLAUSE ( IF ( value == target )\
 THEN\
  1.00000000\
 ELSE\
  0.00000000\
 ENDIF )\
 END_ELSEIF\
 ELSEIF_COND ( direction == "<" )\
 ELSEIF_CLAUSE ( IF ( value < target )\
 THEN\
  1.00000000\
 ELSE\
  0.00000000\
 ENDIF )\
 END_ELSEIF\
 ELSEIF_COND ( direction == ">" )\
 ELSEIF_CLAUSE ( IF ( value > target )\
 THEN\
  1.00000000\
 ELSE\
  0.00000000\
 ENDIF )\
 END_ELSEIF\
 ELSEIF_COND ( direction == "!=" )\
 ELSEIF_CLAUSE ( IF ( value != target )\
 THEN\
  1.00000000\
 ELSE\
  0.00000000\
 ENDIF )\
 END_ELSEIF;\
\
    END\
    UUID "{ba9dc63c-3266-43e8-b336-3926db9ff231}";;\
\
    FUNCTION       "GetRunRange" (  )\
    RETURN_TYPE    LIST;\
    SCALE_UNITS    "";\
    DESCRIPTION    "";\
    ACTIVE         TRUE;\
    PRE_EXEC_DIAG  FALSE;\
    POST_EXEC_DIAG FALSE;\
    NOTES          "";\
    BEGIN\
\
      @"Start Timestep" TO @"Finish Timestep";\
\
    END\
    UUID "{a87340d0-d207-4fd0-87dc-fc4005bd6935}";;\
\
    FUNCTION       "GetNumberOfSatisfactoryTimesteps" ( SLOT slot, NUMERIC target, STRING direction )\
    RETURN_TYPE    NUMERIC;\
    SCALE_UNITS    "";\
    DESCRIPTION    "";\
    ACTIVE         TRUE;\
    PRE_EXEC_DIAG  FALSE;\
    POST_EXEC_DIAG TRUE;\
    NOTES          "";\
    BEGIN\
\
      FOR ( DATETIME date IN "GetRunRange"(  ) ) WITH NUMERIC result = 0.00000000 DO\
  result + "IsSatisfactory"( slot [date], target, direction )\
 ENDFOR;\
\
    END\
    UUID "{fb9fc90c-122b-46f3-9039-8949e7569829}";;\
\
  END\
  UUID "{55dba6b3-34ed-4005-a424-2290f9ccbc48}";;\
\
END\
UUID "{df1ad457-9a48-4b6a-a314-1386d226eae1}";\
}
# Section: RuleSet Manager
Section {RuleSet Manager}
set rsm "$ws.RulesetMgr"
$rsm saveLoadedSetWithModel true
$rsm loadedSet {RULESET\
NAME "RPL Set";\
AGENDA_ORDER ASCENDING;\
DESCRIPTION "";\
PRECISION   2;\
NOTES "";\
BEGIN\
\
  POLICY_GROUP   "Policy Group";\
  DESCRIPTION    "";\
  ACTIVE         TRUE;\
  NOTES          "";\
  BEGIN\
\
    RULE                 "Elevation Max";\
    DESCRIPTION          "";\
    ACTIVE               TRUE;\
    RULE_EXEC_CONSTRAINT TRUE;\
    NOTES                "";\
    BEGIN\
\
      $ "Res1.Outflow" [] := IF ( $ "Res1.Pool Elevation" [] > $ "Res1.Pool Elevation Max" [] )\
 THEN\
  "OutflowForMaxElevationRules"( % "Res1" )\
 ENDIF;\
\
    END\
    UUID "{0c5c3396-97ac-4ea6-8815-ad371a49b3fe}";;\
\
    RULE                 "Limit Outflow";\
    DESCRIPTION          "";\
    ACTIVE               TRUE;\
    RULE_EXEC_CONSTRAINT TRUE;\
    NOTES                "";\
    BEGIN\
\
      $ "Res1.Outflow" [] := IF ( $ "Res1.Outflow" [] > $ "Res1.Outflow Limit" [] )\
 THEN\
  "Min"( $ "Res1.Outflow Limit" [], "GetMaxOutflowGivenInflow"( % "Res1", % "Res1" & "Inflow" [], @"t" ) )\
 ENDIF;\
\
    END\
    UUID "{fa406670-e217-4e52-9172-f7732db31cf6}";;\
\
    RULE                 "Flood Control";\
    DESCRIPTION          "";\
    ACTIVE               TRUE;\
    RULE_EXEC_CONSTRAINT TRUE;\
    NOTES                "";\
    BEGIN\
\
      $ "Res1.Outflow" [] := IF ( $ "Res1.Pool Elevation" [] > $ "Res1.Flood Control Target" [] AND ( @"t" >= @"April" AND @"t" <= @"August" ) )\
 THEN\
  "OutflowForFloodControl"( % "Res1", $ "Res1.Flood Control Target" [] )\
 ENDIF;\
\
    END\
    UUID "{46e0760f-c460-4775-a60b-5dc976432671}";;\
\
    RULE                 "Meet Demand with Hedging";\
    DESCRIPTION          "";\
    ACTIVE               TRUE;\
    RULE_EXEC_CONSTRAINT TRUE;\
    NOTES                "";\
    BEGIN\
\
      $ "Res1.Outflow" [] := WITH NUMERIC available_vol = "FlowToVolume"( "SolveOutflow"( % "Res1", % "Res1" & "Inflow" [], "ElevationToStorage"( % "Res1", % "Res1" & "Pool Elevation Min" [] ), % "Res1" & "Storage" [@"t - 1"], @"t" ), @"t" ) DO\
  IF ( available_vol > $ "Res1.Hedging Parameter" [] * $ "Res1.Demand Vol" [] )\
  THEN\
   "OutflowForDemandVol"( % "Res1", $ "Res1.Demand Vol" [] )\
  ELSE\
   "OutflowForDemandVol"( % "Res1", available_vol / $ "Res1.Hedging Parameter" [] )\
  ENDIF\
 ENDWITH;\
\
    END\
    UUID "{9a83d21d-14d4-49a8-af60-439dd55cf2cf}";;\
\
    RULE                 "Elevation Min";\
    DESCRIPTION          "";\
    ACTIVE               TRUE;\
    RULE_EXEC_CONSTRAINT TRUE;\
    NOTES                "";\
    BEGIN\
\
      $ "Res1.Outflow" [] := IF ( $ "Res1.Pool Elevation" [] < $ "Res1.Pool Elevation Min" [] )\
 THEN\
  "OutflowForMinElevationRules"( % "Res1" )\
 ENDIF;\
\
    END\
    UUID "{65633cab-077d-4098-afe3-a5b7e53bfa0d}";;\
\
    RULE                 "Minimum Outflow";\
    DESCRIPTION          "";\
    ACTIVE               TRUE;\
    RULE_EXEC_CONSTRAINT TRUE;\
    NOTES                "";\
    BEGIN\
\
      $ "Res1.Outflow" [] := "Min"( $ "Res1.Outflow Min" [], "GetMaxOutflowGivenInflow"( % "Res1", % "Res1" & "Inflow" [], @"t" ) );\
\
    END\
    UUID "{e2466ad2-afeb-4429-a07d-dfb9192357b8}";;\
\
  END\
  UUID "{9d5c0f0c-9f5d-4c05-b6f7-27c3bb744a02}";;\
\
  UTILITY_GROUP "Utility Group";\
  DESCRIPTION   "";\
  ACTIVE        TRUE;\
  NOTES          "";\
  BEGIN\
\
    FUNCTION       "OutflowForMinElevationRules" ( OBJECT res )\
    RETURN_TYPE    NUMERIC;\
    SCALE_UNITS    "";\
    DESCRIPTION    "";\
    ACTIVE         TRUE;\
    PRE_EXEC_DIAG  FALSE;\
    POST_EXEC_DIAG FALSE;\
    NOTES          "";\
    BEGIN\
\
      "Max"( "SolveOutflow"( res, res & "Inflow" [], "ElevationToStorage"( res, res & "Pool Elevation Min" [] ), res & "Storage" [@"t - 1"], @"t" ), 0.00000000 "cms" );\
\
    END\
    UUID "{8ef4e5c8-e7df-43fa-8a62-b10c07c5c355}";;\
\
    FUNCTION       "OutflowForMaxElevationRules" ( OBJECT res )\
    RETURN_TYPE    NUMERIC;\
    SCALE_UNITS    "";\
    DESCRIPTION    "";\
    ACTIVE         TRUE;\
    PRE_EXEC_DIAG  FALSE;\
    POST_EXEC_DIAG FALSE;\
    NOTES          "";\
    BEGIN\
\
      "Min"( "SolveOutflow"( res, res & "Inflow" [], "ElevationToStorage"( res, res & "Pool Elevation Max" [] ), res & "Storage" [@"t - 1"], @"t" ), "GetMaxOutflowGivenInflow"( res, res & "Inflow" [], @"t" ) );\
\
    END\
    UUID "{08e9df30-f077-428f-8ea2-d75483ed115e}";;\
\
    FUNCTION       "OutflowForFloodControl" ( OBJECT res, NUMERIC flood_threshold )\
    RETURN_TYPE    NUMERIC;\
    SCALE_UNITS    "";\
    DESCRIPTION    "";\
    ACTIVE         TRUE;\
    PRE_EXEC_DIAG  FALSE;\
    POST_EXEC_DIAG FALSE;\
    NOTES          "";\
    BEGIN\
\
      "Min"( "SolveOutflow"( res, res & "Inflow" [], "ElevationToStorage"( res, flood_threshold ), res & "Storage" [@"t - 1"], @"t" ), "GetMaxOutflowGivenInflow"( res, res & "Inflow" [], @"t" ) );\
\
    END\
    UUID "{fbcec297-f241-4a36-a412-12f4fc219873}";;\
\
    FUNCTION       "OutflowForDemandVol" ( OBJECT res, NUMERIC desired_vol )\
    RETURN_TYPE    NUMERIC;\
    SCALE_UNITS    "";\
    DESCRIPTION    "";\
    ACTIVE         TRUE;\
    PRE_EXEC_DIAG  FALSE;\
    POST_EXEC_DIAG FALSE;\
    NOTES          "";\
    BEGIN\
\
      "Max"( "Min"( "VolumeToFlow"( desired_vol, @"t" ), "GetMaxOutflowGivenInflow"( res, res & "Inflow" [@"t"], @"t" ) ), 0.00000000 "cfs" );\
\
    END\
    UUID "{6967e249-1ff5-4d5d-9934-60ddd6b30d47}";;\
\
  END\
  UUID "{691dd080-db95-40c1-bc3a-7ab5a00b5d42}";;\
\
END\
UUID "{cc61621f-0953-4f0c-b563-308e71c4cb78}";\
}
# Section: Optimization Set Manager
Section {Optimization Set Manager}
set mgr "$ws.optSetMgr"
# Section: Optimization
Section {Optimization}
$ws.RplBasedOptController ShouldExecInitRules 0
$ws.RplBasedOptController ShouldRunFromRestorePoint 0
$ws.RplBasedOptController RunFromRestorePointName {}
$ws.RplBasedOptController savePolicyWithModel 1
$ws.RplBasedOptController setParameter {ADVANCE 2}
$ws.RplBasedOptController setParameter {BARRIER CROSSOVER 1}
$ws.RplBasedOptController setParameter {PREPROCESSING AGGREGATOR 10}
$ws.RplBasedOptController setParameter {PREPROCESSING DUAL -1}
$ws.RplBasedOptController setParameter {PREPROCESSING REDUCE 1}
$ws.RplBasedOptController setParameter {SIMPLEX PGRADIENT 4}
$ws.RplBasedOptController setParameter {SIMPLEX TOLERANCES MARKOWITZ 5.000000e-01}
$ws.RplBasedOptController setParameter {SIMPLEX TOLERANCES FEASIBILITY 1.000000e-09}
$ws.RplBasedOptController setParameter {SIMPLEX DISPLAY 0}
$ws.RplBasedOptController setParameter {TIMELIMIT 3.000000e+03}
$ws.RplBasedOptController setParameter {LPMETHOD 1}
# Section: Simulation Controller
Section {Simulation Controller}
$ws.SimControl ShouldExecInitRules 1
# Section: Rule Controller
Section {Rule Controller}
$ws.RuleControl ShouldExecInitRules 1
# Section: Initialization Rules
Section {Initialization Rules}
$ws initRules {RULESET\
NAME "Initialization Rules Set";\
AGENDA_ORDER ASCENDING;\
DESCRIPTION "";\
PRECISION   2;\
NOTES "";\
BEGIN\
\
END\
UUID "{c84a40cb-264e-40fa-85d2-11de32d4c52d}";\
}
